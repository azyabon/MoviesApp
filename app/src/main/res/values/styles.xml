<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Screen">
        <item name="android:clipToPadding">false</item>
        <item name="android:paddingBottom">80dp</item>
    </style>
    <!--Toolbar Styles-->
    <style name="Toolbar" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">@color/background</item>
    </style>
    <style name="Toolbar.TitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/primary</item>
    </style>
    <!--Item Active Indicator Styles-->
    <style name="ItemActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/white</item>
        <item name="android:width">48dp</item>
        <item name="android:height">32dp</item>
        <item name="marginHorizontal">16dp</item>
    </style>
    <!--Text-->
    <style name="TextViewMovieRatingText" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">18sp</item>
    </style>
    <style name="TextViewSectionTitle" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/nunito_bold</item>
    </style>
    <style name="TextViewGenreName" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/nunito_semi_bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="TextViewMovieInfo" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/nunito_semi_bold</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="TextViewMovieOverview" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/nunito_regular</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!--Base Text Styles-->
    <style name="NunitoTextViewStyle" parent="android:Widget.TextView">
        <item name="android:fontFamily">@font/nunito_regular</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="NunitoButtonStyle" parent="android:Widget.Holo.Button">
        <item name="android:fontFamily">@font/nunito_semi_bold</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>